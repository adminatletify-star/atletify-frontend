# Plantilla de variables de entorno del frontend.
# Cópiala como `.env` (ese archivo está en .gitignore) y ajusta lo que necesites.
# Todos estos valores son públicos (terminan embebidos en el bundle del navegador).

# URL base del backend. En local apunta a la API .NET; en prod la inyecta Vercel.
VITE_API_URL=https://localhost:7149

# Cloudinary (subida de imágenes)
VITE_CLOUDINARY_CLOUD_NAME=dy4xhafbk
VITE_CLOUDINARY_UPLOAD_PRESET=wfdpflzt

# Login con Google (id_token). Valor público, mismo en local y prod.
# El MISMO Client ID va en Railway como `Google__ClientId` para verificar el token en el backend.
VITE_GOOGLE_CLIENT_ID=217100953535-nrq0849ot9qch4udkgg03ebdie58ndl4.apps.googleusercontent.com
